    "    \"\\n\",\n",
    "    \"# 初始化一个空列表来存储列数据\\n\",\n",
    "    \"column_data = []\\n\",\n",
    "    \"\\n\",\n",
    "    \"with open('D:\\\\LDA-anaconda\\\\data_0\\\\data_f4500.csv', mode='r', encoding='utf-8') as file:\\n\",\n",
    "    \"    reader = csv.DictReader(file)  # 使用DictReader读取CSV文件\\n\",\n",
    "    \"    for row in reader:\\n\",\n",
    "    \"        column_data.append(row['app'])  # 将\\\"app\\\"列的数据添加到列表中\\n\",\n",
    "    \"\\n\",\n",
    "    \"#先把数据处理成需要的格式\\n\",\n",
    "    \"sentence_cut = [jieba.lcut(line) for line in column_data]\\n\",\n",
    "    \"stopwords = pd.read_csv(\\\"stop_words_ch.txt\\\", header=None, quoting = csv.QUOTE_NONE, delimiter=\\\"\\\\t\\\")\\n\",\n",
    "    \"stopwords = stopwords[0].tolist()\\n\",\n",
    "    \"\\n\",\n",
    "    \"not_stopwords = [[word for word in line if word not in stopwords and len(word)>1]for line in sentence_cut] #到这里就获得了我们需要的模型\\n\",\n",
    "    \"\\n\",\n",
    "    \"model =gensim.models.Word2Vec(not_stopwords,min_count=2,window=5) #送进模型里获得词向量\\n\",\n",
    "    \"words = list(model.wv.key_to_index) #获得所有词汇\\n\"\n",
    "   ]\n",
