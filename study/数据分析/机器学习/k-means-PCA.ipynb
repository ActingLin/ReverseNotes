    "   \"source\": [\n",
    "    \"#进行聚类\\n\",\n",
    "    \"from sklearn.cluster import KMeans\\n\",\n",
    "    \"from sklearn.metrics import silhouette_score\\n\",\n",
    "    \"from sklearn.metrics import silhouette_samples\\n\",\n",
    "    \"\\n\",\n",
    "    \"#先用轮廓系数绘制学习曲线找出最优类别数\\n\",\n",
    "    \"ss = []\\n\",\n",
    "    \"krange = list(range(2,6)) #看一下在2-6之间的得到\\n\",\n",
    "    \"for k in range(2,6):\\n\",\n",
    "    \"    model = KMeans(n_clusters= k,random_state=0)       # 实例化\\n\",\n",
    "    \"    model = model.fit(result)\\n\",\n",
    "    \"    ss.append(silhouette_score(result,model.labels_))\\n\",\n",
    "    \"plt.plot(krange,ss) #当K为_时，最接近1\\n\",\n",
    "    \"#分为_类最佳，根据我们的经验值来判断\"\n",
    "   ]\n",
