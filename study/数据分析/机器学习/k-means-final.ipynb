    "    \"from sklearn.cluster import KMeans\\n\",\n",
    "    \"model_clusters = KMeans(n_clusters= 4,random_state=0,init=\\\"k-means++\\\")\\n\",\n",
    "    \"model_clusters = model_clusters.fit(result)\\n\",\n",
    "    \"# 将聚类的结果和中心点的结果都画在原图里面\\n\",\n",
