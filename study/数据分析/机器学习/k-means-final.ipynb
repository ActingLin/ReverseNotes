    "   \"source\": [\n",
    "    \"  # # 先导入需要的包\\n\",\n",
    "    \"# import pandas as pd\\n\",\n",
    "    \"# import jieba\\n\",\n",
    "    \"# import csv\\n\",\n",
    "    \"# import gensim\\n\",\n",
    "    \"# from pprint import pprint\\n\",\n",
    "    \"#\\n\",\n",
    "    \"# # 初始化一个空列表来存储列数据\\n\",\n",
    "    \"# column_data = []\\n\",\n",
    "    \"# filename = \\\"data_f.csv\\\"\\n\",\n",
    "    \"# with open(filename, mode='r', encoding='utf-8') as file:\\n\",\n",
    "    \"#     reader = csv.DictReader(file)  # 使用DictReader读取CSV文件\\n\",\n",
    "    \"#     for row in reader:\\n\",\n",
    "    \"#         column_data.append(row['app'])  # 将\\\"app\\\"列的数据添加到列表中\\n\",\n",
    "    \"# # print(column_data)\\n\",\n",
    "    \"# # 先把数据处理成需要的格式\\n\",\n",
    "    \"# column_words = [[word] for word in column_data]\\n\",\n",
    "    \"# stopwords = pd.read_csv(\\\"stop_words_ch.txt\\\", header=None, quoting=csv.QUOTE_NONE, delimiter=\\\"\\\\t\\\")\\n\",\n",
    "    \"# stopwords = stopwords[0].tolist()\\n\",\n",
    "    \"# not_stopwords = [[word for word in line if word not in stopwords and len(word) > 1] for line in column_words]\\n\",\n",
    "    \"#\\n\",\n",
    "    \"# # 到这里就获得了我们需要的模型\\n\",\n",
    "    \"# model = gensim.models.Word2Vec(not_stopwords, min_count=130, window=5)  # 送进模型里获得词向量\\n\",\n",
    "    \"# words = list(model.wv.key_to_index)  # 获得所有词汇\\n\",\n",
    "    \"# print(words)\\n\",\n",
    "    \"import pandas as pd\\n\",\n",
    "    \"import jieba\\n\",\n",
    "    \"import csv\\n\",\n",
    "    \"import gensim\\n\",\n",
    "    \"from pprint import pprint\\n\",\n",
    "    \"\\n\",\n",
    "    \"def load_stopwords(filepath):\\n\",\n",
    "    \"    \\\"\\\"\\\"\\n\",\n",
    "    \"    从文件加载停用词表。\\n\",\n",
    "    \"\\n\",\n",
    "    \"    Args:\\n\",\n",
    "    \"        filepath (str): 停用词文件路径。\\n\",\n",
    "    \"\\n\",\n",
    "    \"    Returns:\\n\",\n",
    "    \"        set: 包含所有停用词的集合，用于快速查找。\\n\",\n",
    "    \"    \\\"\\\"\\\"\\n\",\n",
    "    \"    try:\\n\",\n",
    "    \"        # 使用pandas读取，指定列名为'word'以便于访问\\n\",\n",
    "    \"        df = pd.read_csv(filepath, header=None, names=['word'], quoting=csv.QUOTE_NONE, delimiter=\\\"\\\\t\\\")\\n\",\n",
    "    \"        # 转换为集合set，比list查找速度更快 O(1) vs O(n)\\n\",\n",
    "    \"        return set(df['word'].tolist())\\n\",\n",
    "    \"    except FileNotFoundError:\\n\",\n",
    "    \"        print(f\\\"警告: 停用词文件 '{filepath}' 未找到，将不使用停用词过滤。\\\")\\n\",\n",
    "    \"        return set()\\n\",\n",
    "    \"\\n\",\n",
    "    \"def read_column_from_csv(filepath, column_name):\\n\",\n",
    "    \"    \\\"\\\"\\\"\\n\",\n",
    "    \"    从CSV文件中高效地读取指定列的所有数据。\\n\",\n",
    "    \"\\n\",\n",
    "    \"    Args:\\n\",\n",
    "    \"        filepath (str): CSV文件路径。\\n\",\n",
    "    \"        column_name (str): 要读取的列名。\\n\",\n",
    "    \"\\n\",\n",
    "    \"    Returns:\\n\",\n",
    "    \"        list: 该列所有数据组成的列表。\\n\",\n",
    "    \"    \\\"\\\"\\\"\\n\",\n",
    "    \"    data = []\\n\",\n",
    "    \"    with open(filepath, mode='r', encoding='utf-8') as file:\\n\",\n",
    "    \"        reader = csv.DictReader(file)\\n\",\n",
    "    \"        # 直接遍历并提取所需列，避免加载整个DataFrame\\n\",\n",
    "    \"        for row in reader:\\n\",\n",
    "    \"            # 可以在这里加入数据清洗逻辑，例如去除首尾空格\\n\",\n",
    "    \"            data.append(row.get(column_name, '').strip())\\n\",\n",
    "    \"    return data\\n\",\n",
    "    \"\\n\",\n",
    "    \"def main():\\n\",\n",
    "    \"    \\\"\\\"\\\"\\n\",\n",
    "    \"    主函数，执行词向量训练流程。\\n\",\n",
    "    \"    \\\"\\\"\\\"\\n\",\n",
    "    \"    # --- 配置 ---\\n\",\n",
    "    \"    filename = \\\"data_f1000.csv\\\"\\n\",\n",
    "    \"    stopword_file = \\\"stop_words_ch.txt\\\"\\n\",\n",
    "    \"    target_column = 'app'\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # --- 步骤 1: 加载数据 ---\\n\",\n",
    "    \"    print(\\\"正在读取数据...\\\")\\n\",\n",
    "    \"    column_data = read_column_from_csv(filename, target_column)\\n\",\n",
    "    \"    if not column_data:\\n\",\n",
    "    \"        print(\\\"错误: 未读取到任何数据，请检查文件路径和列名。\\\")\\n\",\n",
    "    \"        return\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # --- 步骤 2: 加载停用词 ---\\n\",\n",
    "    \"    print(\\\"正在加载停用词...\\\")\\n\",\n",
    "    \"    stop_words_set = load_stopwords(stopword_file)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # --- 步骤 3: 数据预处理 ---\\n\",\n",
    "    \"    # 注意: 这里的代码假设 'column_data' 中的每个元素本身就是一个词。\\n\",\n",
    "    \"    # 如果 'app' 列的单元格包含的是句子或短语，需要用 jieba 分词。\\n\",\n",
    "    \"    # 示例: \\\"社交媒体应用\\\" -> [\\\"社交\\\", \\\"媒体\\\", \\\"应用\\\"]\\n\",\n",
    "    \"    #\\n\",\n",
    "    \"    # 假设原始数据已经是单个词，我们将其包装成句子格式供Word2Vec使用\\n\",\n",
    "    \"    print(\\\"正在进行数据预处理（去停用词、过滤短词）...\\\")\\n\",\n",
    "    \"    processed_sentences = []\\n\",\n",
    "    \"    for text in column_data:\\n\",\n",
    "    \"        # 如果text是句子，则分词；如果是单词，则直接放入列表\\n\",\n",
    "    \"        # words_in_text = jieba.lcut(text) if text else [] # 如果需要分词，请取消注释此行\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # 当前逻辑：假设text本身就是一个词\\n\",\n",
    "    \"        word_list = [text] if text else []\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # 过滤掉停用词和长度小于等于1的词\\n\",\n",
    "    \"        filtered_words = [word for word in word_list if word not in stop_words_set and len(word) > 1]\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # 只有当过滤后还有词时，才将这个“句子”加入训练集\\n\",\n",
    "    \"        if filtered_words:\\n\",\n",
    "    \"            processed_sentences.append(filtered_words)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    if not processed_sentences:\\n\",\n",
    "    \"        print(\\\"错误: 预处理后没有可用的句子用于训练，请检查数据和停用词表。\\\")\\n\",\n",
    "    \"        return\\n\",\n",
    "    \"\\n\",\n",
    "    \"    print(f\\\"预处理完成。共有 {len(processed_sentences)} 个句子可用于训练。\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # --- 步骤 4: 训练 Word2Vec 模型 ---\\n\",\n",
    "    \"    print(\\\"正在训练 Word2Vec 模型...\\\")\\n\",\n",
    "    \"    # 增加 workers 参数可以利用多核CPU加速训练\\n\",\n",
    "    \"    model = gensim.models.Word2Vec(\\n\",\n",
    "    \"        sentences=processed_sentences,\\n\",\n",
    "    \"        vector_size=100,  # 新版本参数名，旧版为size\\n\",\n",
    "    \"        window=5,\\n\",\n",
    "    \"        min_count=10, # 出现次数少于10的词会被忽略\\n\",\n",
    "    \"        workers=8,      # 使用8个CPU核心进行训练\\n\",\n",
    "    \"        sg=0           # 0 for CBOW, 1 for Skip-gram\\n\",\n",
    "    \"    )\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # --- 步骤 5: 获取并打印词汇 ---\\n\",\n",
    "    \"    print(\\\"训练完成。正在获取词汇...\\\")\\n\",\n",
    "    \"    words = list(model.wv.key_to_index.keys()) # 获取所有词汇\\n\",\n",
    "    \"    print(f\\\"模型共学习到 {len(words)} 个词汇。\\\")\\n\",\n",
    "    \"    pprint(words)\\n\",\n",
    "    \"\\n\",\n",
    "    \"if __name__ == \\\"__main__\\\":\\n\",\n",
    "    \"    main()\"\n",
    "   ],\n",
